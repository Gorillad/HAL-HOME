# Stripe TEST mode keys — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Fixed sales tax rate applied at checkout (Stripe Tax Rate)
STRIPE_TAX_PERCENT=12

# Optional: reuse an existing Stripe tax rate ID instead of auto-creating one
# STRIPE_TAX_RATE_ID=txr_your_tax_rate_id

# Use Stripe Tax automatic calculation instead of STRIPE_TAX_PERCENT
# STRIPE_AUTOMATIC_TAX=true

# Webhook signing secret — run: stripe listen --forward-to localhost:4242/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Site URL (no trailing slash)
BASE_URL=http://localhost:4242

# Server port
PORT=4242
